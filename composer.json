{
    "name": "psc-acme/tracker-auth",
    "description": "Package tracker-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\TrackerAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "doctrine/orm": "^3.0",
        "symfony/filesystem": "^7.0",
        "symfony/process": "^7.0",
        "doctrine/doctrine-bundle": "^2.13",
        "psr/cache": "^3.0",
        "illuminate/support": "^11.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}